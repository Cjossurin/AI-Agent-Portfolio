# =============================================================================
# AI Agent Ecosystem — Root .gitignore
# Covers: alita-social-agent | chucky-persona-bot | jergen-credit-ai
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Environment Variables & Secrets  ← NEVER COMMIT THESE
# -----------------------------------------------------------------------------
.env
.env.*
*.env
.env.local
.env.development
.env.staging
.env.production
.env.test

# API key files & credential stores
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
secrets.json
credentials.json
service_account.json
token.json
token.pickle
oauth_token.json
oauth_creds.json
*_secrets.*
*_credentials.*
api_keys.*
gcp_credentials.json
firebase_credentials.json

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.conda/
conda-env/
.python-version

# -----------------------------------------------------------------------------
# Project-Specific Sensitive Directories
# -----------------------------------------------------------------------------

# Jergen — Client PII (SSNs, credit data) — NEVER commit
Dispute Letters/
Input Reports/

# Jergen — Locally generated vector index & immutable audit log
chroma_db/
audit_logs/

# Alita — Runtime logs, session storage, generated media temp files
logs/
storage/
temp/
voice_profiles/

# Chucky — private reference/generated media (keep local only)
chucky-persona-bot/Chucky AI/assets/
chucky-persona-bot/Chucky AI/out/
chucky-persona-bot/Chucky AI/remotion-vhs/public/assets/
chucky-persona-bot/Chucky AI/remotion-vhs/out/
chucky-persona-bot/Chucky AI/Reference Library/**/*.png
chucky-persona-bot/Chucky AI/Reference Library/**/*.jpg
chucky-persona-bot/Chucky AI/Reference Library/**/*.jpeg
chucky-persona-bot/Chucky AI/Reference Library/**/*.webp
chucky-persona-bot/Chucky AI/Reference Library/**/*.gif

# -----------------------------------------------------------------------------
# Generated Media Artifacts (AI-generated output — do not commit)
# -----------------------------------------------------------------------------
*.mp4
*.mp3
*.wav
*.mkv
*.mov

